# ─── CONFIGURACIÓN DE ENTORNO — CELUACCEL ──────────────────────────
# Copia este archivo como ".env" y rellena con tus valores locales.
# NUNCA subas el archivo ".env" real al repositorio.
#
# Comando para copiar:
#   Windows: copy .env.example .env
#   Linux/Mac: cp .env.example .env
# ───────────────────────────────────────────────────────────────────

# Clave secreta para firma de tokens JWT
# Reemplaza por cualquier cadena larga y aleatoria en producción
JWT_SECRET=CeluAccel_S3cr3t_K3y_2026!#Secure

# Puerto del servidor backend (por defecto 3000)
PORT=3000

