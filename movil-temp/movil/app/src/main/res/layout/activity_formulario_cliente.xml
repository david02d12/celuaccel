<?xml version="1.0" encoding="utf-8"?>
<!-- activity_formulario_cliente.xml — CeluAccel -->
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/celuaccel_bg"
        android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

        <!-- Header Gradiente con Botón de Regresar -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_header"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:elevation="6dp">

            <Button
                    android:id="@+id/btnRegresarClienteForm"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:background="@drawable/bg_avatar_white_alpha"
                    android:padding="0dp"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Ficha del Cliente"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
        </LinearLayout>

        <!-- Contenedor del Formulario (Tarjeta Elevada) -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_elevated"
                android:elevation="4dp"
                android:layout_margin="16dp"
                android:padding="20dp">

            <!-- Fila: Tipo Doc y Número Documento (ID_Usuario) -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Identificación Oficial *"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp">

                <Spinner
                        android:id="@+id/spinnerTipoDocClienteForm"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_field"/>

                <EditText
                        android:id="@+id/txtIdClienteForm"
                        android:layout_width="0dp"
                        android:layout_height="46dp"
                        android:layout_weight="1.2"
                        android:layout_marginStart="8dp"
                        android:hint="Número de Doc"
                        android:inputType="number"
                        android:paddingLeft="12dp"
                        android:textSize="14sp"
                        android:textColor="@color/celuaccel_text"
                        android:background="@drawable/bg_input_field"/>
            </LinearLayout>

            <!-- Campo: Nombre Completo -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre Completo *"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <EditText
                    android:id="@+id/txtNombreClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:hint="Ej. Juan Pérez"
                    android:inputType="textPersonName"
                    android:paddingLeft="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/celuaccel_text"
                    android:background="@drawable/bg_input_field"/>

            <!-- Campo: Correo Electrónico -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Correo Electrónico *"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <EditText
                    android:id="@+id/txtCorreoClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:hint="correo@ejemplo.com"
                    android:inputType="textEmailAddress"
                    android:paddingLeft="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/celuaccel_text"
                    android:background="@drawable/bg_input_field"/>

            <!-- Campo: Teléfono / Celular -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Teléfono / Celular"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <EditText
                    android:id="@+id/txtTelefonoClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:hint="3001234567"
                    android:inputType="phone"
                    android:paddingLeft="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/celuaccel_text"
                    android:background="@drawable/bg_input_field"/>

            <!-- Campo: Dirección de Residencia -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dirección"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <EditText
                    android:id="@+id/txtDireccionClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:hint="Calle 123 # 45 - 67"
                    android:inputType="textPostalAddress"
                    android:paddingLeft="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/celuaccel_text"
                    android:background="@drawable/bg_input_field"/>

            <!-- Fila Doble: Fecha Nacimiento y Contraseña -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha Nac."
                            android:textColor="@color/celuaccel_text"
                            android:textStyle="bold"
                            android:textSize="13sp"/>

                    <EditText
                            android:id="@+id/txtFechaNacClienteForm"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:hint="AAAA-MM-DD"
                            android:inputType="date"
                            android:paddingLeft="12dp"
                            android:textSize="14sp"
                            android:textColor="@color/celuaccel_text"
                            android:background="@drawable/bg_input_field"/>
                </LinearLayout>

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contraseña *"
                            android:textColor="@color/celuaccel_text"
                            android:textStyle="bold"
                            android:textSize="13sp"/>

                    <EditText
                            android:id="@+id/txtClaveClienteForm"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="6dp"
                            android:hint="Clave de acceso"
                            android:inputType="textPassword"
                            android:paddingLeft="12dp"
                            android:textSize="14sp"
                            android:textColor="@color/celuaccel_text"
                            android:background="@drawable/bg_input_field"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Campo: Selector de Rol de Sistema -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Rol del Usuario *"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <Spinner
                    android:id="@+id/spinnerRolClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_input_field"/>

            <!-- SECCIÓN ACCIONES CRUD: Botones de Operación -->
            <Button
                    android:id="@+id/btnRegistrarClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Crear Nuevo Registro"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/celuaccel_primary"
                    android:layout_marginBottom="10dp"/>

            <Button
                    android:id="@+id/btnActualizarClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Guardar Cambios Existentes"
                    android:textColor="@color/celuaccel_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_outline"
                    android:backgroundTint="@android:color/transparent"
                    android:layout_marginBottom="10dp"/>

            <Button
                    android:id="@+id/btnEliminarClienteForm"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Dar de Baja Cliente"
                    android:textColor="@color/etapa_cancelado_text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/etapa_cancelado_bg"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>