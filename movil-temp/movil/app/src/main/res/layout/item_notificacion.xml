<?xml version="1.0" encoding="utf-8"?>
<!--
  item_notificacion.xml — CeluAccel
  Card de notificación con punto rojo de "no leída"
  igual que en MisNotificaciones.jsx / Notificaciones.jsx
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_elevated"
    android:elevation="2dp"
    android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
    android:layout_marginBottom="8dp"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Punto de no leída -->
    <View
        android:id="@+id/dotNoLeida"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_avatar_circle"
        android:layout_marginEnd="12dp"/>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloNotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tu servicio está listo"
            android:textColor="@color/celuaccel_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="3dp"/>

        <TextView
            android:id="@+id/tvMensajeNotif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tu dispositivo ya puede ser retirado en nuestra tienda."
            android:textColor="@color/celuaccel_text_muted"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvFechaNotif"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="hace 2 horas"
            android:textColor="@color/celuaccel_text_light"
            android:textSize="11sp"/>
    </LinearLayout>

</LinearLayout>
