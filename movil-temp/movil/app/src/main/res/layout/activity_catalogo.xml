<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_catalogo.xml — CeluAccel
  Header gradiente + barra de búsqueda + grid de productos (2 columnas)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/celuaccel_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="16dp" android:paddingBottom="16dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnRegresar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_avatar_white_alpha"
            android:padding="0dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catálogo de Productos"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accesorios y repuestos"
                android:textColor="#CCffffff"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Barra de búsqueda y filtro -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/celuaccel_surface"
        android:elevation="2dp">

        <EditText
            android:id="@+id/etBuscarCatalogo"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="🔍  Buscar productos..."
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:paddingTop="0dp" android:paddingBottom="0dp"
            android:background="@drawable/bg_input_field"
            android:textSize="14sp"
            android:textColor="@color/celuaccel_text"
            android:textColorHint="@color/celuaccel_text_light"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:layout_marginEnd="8dp"/>

        <Spinner
            android:id="@+id/spinnerCategoriaCatalogo"
            android:layout_width="120dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:paddingLeft="10dp" android:paddingRight="10dp"/>
    </LinearLayout>

    <!-- Grid de productos (2 columnas) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCatalogo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false"/>

</LinearLayout>
