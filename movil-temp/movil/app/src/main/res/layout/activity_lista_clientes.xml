<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/celuaccel_bg">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:elevation="6dp">

        <Button
                android:id="@+id/btnRegresarListaClientes"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/bg_avatar_white_alpha"
                android:padding="0dp"/>

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Control de Clientes"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            <TextView
                    android:id="@+id/tvTotalClientes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cargando base de datos..."
                    android:textColor="#CCffffff"
                    android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/celuaccel_surface"
            android:elevation="2dp">

        <EditText
                android:id="@+id/etBuscarCliente"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="🔍  Buscar por nombre o documento..."
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:inputType="text"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerClientes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:clipToPadding="false"/>

</LinearLayout>