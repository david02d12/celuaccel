<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/celuaccel_bg"
        android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_header"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:elevation="4dp">

            <Button
                    android:id="@+id/btnRegresarDetalle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:background="@drawable/bg_avatar_white_alpha"
                    android:padding="0dp"/>

            <TextView
                    android:id="@+id/tvTituloDetalleHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Detalle del Producto"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_elevated"
                android:layout_margin="16dp"
                android:padding="16dp"
                android:elevation="3dp">

            <TextView
                    android:id="@+id/tvNombreDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre Producto"
                    android:textColor="@color/celuaccel_text"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

            <TextView
                    android:id="@+id/tvCategoriaDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/celuaccel_primary"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

            <TextView
                    android:id="@+id/tvPrecioDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="@color/celuaccel_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

            <TextView
                    android:id="@+id/tvStockDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Stock disponible"
                    android:textColor="@color/celuaccel_text_muted"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

            <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/celuaccel_border"
                    android:layout_marginBottom="16dp"/>

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción:"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

            <TextView
                    android:id="@+id/tvDescripcionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción detallada aquí"
                    android:textColor="@color/celuaccel_text"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>
        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_elevated"
                android:layout_marginHorizontal="16dp" android:padding="16dp"
                android:elevation="3dp">

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Tienes dudas sobre este repuesto o equipo?"
                    android:textColor="@color/celuaccel_text"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="4dp"/>

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Al enviar tu consulta se abrirá un canal de soporte técnico de inmediato."
                    android:textColor="@color/celuaccel_text_muted"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

            <EditText
                    android:id="@+id/etPreguntaTecnico"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="Ej: ¿Este display es compatible con la versión global del dispositivo?"
                    android:background="@drawable/bg_input_field"
                    android:gravity="top|start"
                    android:padding="10dp"
                    android:textSize="13sp"
                    android:textColor="@color/celuaccel_text"
                    android:inputType="textMultiLine"/>

            <Button
                    android:id="@+id/btnEnviarPregunta"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="Chatear con el Técnico"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="@color/celuaccel_primary"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>