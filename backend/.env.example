# ─── CONFIGURACIÓN DE ENTORNO — CELUACCEL ──────────────────────────
# Copia este archivo como ".env" y rellena con tus valores locales.
# NUNCA subas el archivo ".env" real al repositorio.
#
# Comando para copiar:
#   Windows: copy .env.example .env
#   Linux/Mac: cp .env.example .env
# ───────────────────────────────────────────────────────────────────

# Clave secreta para firma de tokens JWT
# Reemplaza por cualquier cadena larga y aleatoria en producción
JWT_SECRET=CeluAccel_S3cr3t_K3y_2026!#Secure

# Puerto del servidor backend (por defecto 3000)
PORT=3000

# ─── BASE DE DATOS MySQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql
DB_NAME=celuaccel

# ─── CORS — URL del frontend ────────────────────────────────────────
# En desarrollo: http://localhost:5173
# En producción: https://tudominio.com
FRONTEND_URL=http://localhost:5173

# ─── CORREO (Nodemailer + Gmail) ────────────────────────────────────
# Necesario para el flujo de recuperación de contraseña.
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta Google
# y usa esa contraseña de 16 dígitos aquí (NO tu contraseña normal).
EMAIL_USER=tucorreo@gmail.com
EMAIL_PASS=abcd efgh ijkl mnop

