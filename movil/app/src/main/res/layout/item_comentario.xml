<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_elevated"
    android:elevation="3dp"
    android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
    android:layout_marginBottom="10dp"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvAvatarComentario"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="C"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreComentario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cliente"
                android:textColor="@color/celuaccel_text"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFechaComentario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/celuaccel_text_light"
                android:textSize="11sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnEditComentario"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✎"
                android:textSize="18sp"
                android:textColor="@color/celuaccel_info"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/btnDeleteComentario"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textSize="18sp"
                android:textColor="@color/celuaccel_danger"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/starContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvTextoComentario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/celuaccel_text"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:paddingTop="4dp"/>
</LinearLayout>
