<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_roles.xml — CeluAccel
  Header gradiente + formulario CRUD roles + lista
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/celuaccel_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="16dp" android:paddingBottom="16dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnRegresar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_avatar_white_alpha"
            android:padding="0dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestión de Roles"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Administración de accesos"
                android:textColor="#CCffffff"
                android:textSize="12sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnNuevoRol"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Nuevo"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:background="@drawable/bg_btn_outline_white"/>
    </LinearLayout>

    <!-- Formulario CRUD -->
    <LinearLayout
        android:id="@+id/cardFormRol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="12dp"
        android:background="@drawable/bg_card_elevated"
        android:elevation="3dp"
        android:padding="16dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/etNombreRol"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nombre del rol"
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:paddingTop="0dp" android:paddingBottom="0dp"
            android:background="@drawable/bg_input_field"
            android:textSize="14sp"
            android:textColor="@color/celuaccel_text"
            android:textColorHint="@color/celuaccel_text_light"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGuardarRol"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnCancelarRol"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_primary"
                android:background="@drawable/bg_btn_outline"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRoles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/celuaccel_surface"
        android:elevation="2dp"/>

</LinearLayout>