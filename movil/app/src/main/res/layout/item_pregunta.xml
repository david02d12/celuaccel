<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_elevated"
    android:elevation="3dp"
    android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
    android:layout_marginBottom="10dp"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTituloPregunta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="¿Cuánto demora la reparación?"
            android:textColor="@color/celuaccel_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvExpandir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▼"
            android:textColor="@color/celuaccel_primary"
            android:textSize="12sp"/>
    </LinearLayout>

    
    <TextView
        android:id="@+id/tvContenidoPregunta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quisiera saber los tiempos aproximados."
        android:textColor="@color/celuaccel_text_muted"
        android:textSize="13sp"
        android:layout_marginTop="6dp"
        android:maxLines="2"
        android:ellipsize="end"/>

    
    <View
        android:id="@+id/separadorRespuesta"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/celuaccel_border"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"/>

    
    <LinearLayout
        android:id="@+id/layoutRespuesta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top"
        android:visibility="gone">

        <View
            android:layout_width="3dp"
            android:layout_height="match_parent"
            android:background="@color/celuaccel_primary"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESPUESTA"
                android:textColor="@color/celuaccel_primary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvRespuestaPregunta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El tiempo depende del tipo de reparación."
                android:textColor="@color/celuaccel_text"
                android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tvFechaPregunta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="01/01/2025"
            android:textColor="@color/celuaccel_text_light"
            android:textSize="11sp"/>

        <Button
            android:id="@+id/btnResponder"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Responder"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/celuaccel_primary"
            android:background="@drawable/bg_btn_outline"
            android:paddingLeft="12dp" android:paddingRight="12dp"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>
