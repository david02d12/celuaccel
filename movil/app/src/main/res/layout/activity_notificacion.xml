<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_notificacion.xml — CeluAccel
  Header gradiente + pills de filtro (Todas / Sin leer / Leídas) + RecyclerView
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/celuaccel_bg">

    <!-- ── Header Gradiente ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="16dp" android:paddingBottom="16dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnRegresar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_avatar_white_alpha"
            android:padding="0dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notificaciones"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Conteo dinámico: "3 notificaciones · 2 sin leer" -->
            <TextView
                android:id="@+id/tvConteoNotif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando..."
                android:textColor="#CCffffff"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Botón Nueva Notificación (solo técnico/admin) -->
        <Button
            android:id="@+id/btnNuevaNotificacion"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Nueva"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:background="@drawable/bg_btn_outline_white"/>
    </LinearLayout>

    <!-- ── Pills de Filtro ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingLeft="12dp" android:paddingRight="12dp"
        android:paddingTop="12dp" android:paddingBottom="8dp"
        android:background="@color/celuaccel_surface"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Pill: Todas -->
            <Button
                android:id="@+id/btnFiltroTodas"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Todas"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_primary"
                android:textColor="#FFFFFF"/>

            <!-- Pill: Sin leer -->
            <Button
                android:id="@+id/btnFiltroNuevas"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Sin leer"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_btn_outline"
                android:textColor="@color/celuaccel_primary"/>

            <!-- Pill: Leídas -->
            <Button
                android:id="@+id/btnFiltroLeidas"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="✓ Leídas"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@drawable/bg_btn_outline"
                android:textColor="@color/celuaccel_primary"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Lista ── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNotificaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
