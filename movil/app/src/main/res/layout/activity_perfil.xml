<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_perfil.xml — CeluAccel
  Diseño idéntico al componente Perfil.jsx del frontend web:
  • Header gradiente rojo con flecha regresar
  • Avatar circular con iniciales
  • Cards de sección con título rojo
  • Inputs redondeados
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celuaccel_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header gradiente ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="16dp" android:paddingBottom="16dp"
            android:elevation="6dp">

            <Button
                android:id="@+id/btnRegresarPerfil"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/bg_avatar_white_alpha"
                android:padding="0dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mi Perfil"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <!-- ── Avatar con iniciales ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/celuaccel_primary_light"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvInicialPerfil"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:text="?"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ── Card: Información Personal ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="3dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información Personal"
                android:textColor="@color/celuaccel_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Nombre -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMBRE COMPLETO"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etNombrePerfil"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nombre completo"
                android:inputType="textPersonName"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="14dp"/>

            <!-- Correo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORREO ELECTRÓNICO"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etCorreoPerfil"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="correo@ejemplo.com"
                android:inputType="textEmailAddress"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="14dp"/>

            <!-- Teléfono -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TELÉFONO"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etTelefonoPerfil"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Número de teléfono"
                android:inputType="phone"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="14dp"/>

            <!-- Dirección -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIRECCIÓN"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etDireccionPerfil"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Dirección"
                android:inputType="textPostalAddress"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnGuardarPerfil"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Guardar cambios"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary"
                android:elevation="3dp"/>
        </LinearLayout>

        <!-- ── Card: Cambiar Contraseña ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="16dp" android:layout_marginRight="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="3dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cambiar Contraseña"
                android:textColor="@color/celuaccel_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etOldPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Contraseña actual"
                android:inputType="textPassword"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="14dp"/>

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nueva contraseña"
                android:inputType="textPassword"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="14dp"/>

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Confirmar nueva contraseña"
                android:inputType="textPassword"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_text"
                android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="20dp"/>

            <Button
                android:id="@+id/btnCambiarPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Cambiar contraseña"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/celuaccel_primary"
                android:background="@drawable/bg_btn_outline"
                android:elevation="0dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
