<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/celuaccel_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="16dp" android:paddingBottom="16dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnRegresar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_avatar_white_alpha"
            android:padding="0dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Muro de Testimonios"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reseñas y comentarios"
                android:textColor="#CCffffff"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    
    <LinearLayout
        android:id="@+id/formPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_elevated"
        android:elevation="2dp"
        android:padding="16dp"
        android:layout_margin="12dp">

        <EditText
            android:id="@+id/etComentario"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Escribe tu testimonio aquí..."
            android:inputType="textMultiLine"
            android:gravity="top"
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:paddingTop="12dp"
            android:background="@drawable/bg_input_field"
            android:textSize="14sp"
            android:textColor="@color/celuaccel_text"
            android:textColorHint="@color/celuaccel_text_light"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calificación:"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:id="@+id/star1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="24sp"
                android:textColor="#FFD700"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/star2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="24sp"
                android:textColor="#FFD700"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/star3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="24sp"
                android:textColor="#FFD700"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/star4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="24sp"
                android:textColor="#FFD700"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/star5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="☆"
                android:textSize="24sp"
                android:textColor="#FFD700"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="?selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnPublicar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Publicar Experiencia"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/btnCancelarEdicion"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Cancelar Edición"
            android:textSize="14sp"
            android:background="@drawable/bg_btn_outline"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>
    </LinearLayout>

    
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingBottom="6dp"
        android:text="Comentarios"
        android:textColor="@color/celuaccel_text_muted"
        android:textSize="12sp"
        android:textStyle="bold"/>

    
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerComentarios"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="12dp" android:paddingRight="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>
</LinearLayout>
