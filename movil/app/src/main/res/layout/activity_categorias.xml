<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_categorias.xml — CeluAccel
  Header gradiente + formulario CRUD + búsqueda + RecyclerView
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/celuaccel_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="16dp" android:paddingBottom="16dp"
        android:elevation="6dp">

        <Button
            android:id="@+id/btnRegresar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@drawable/bg_avatar_white_alpha"
            android:padding="0dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categorías"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestión de categorías"
                android:textColor="#CCffffff"
                android:textSize="12sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnNuevaCategoria"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="+ Nueva"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:background="@drawable/bg_btn_outline_white"/>
    </LinearLayout>

    <!-- Formulario (visible al crear/editar) -->
    <LinearLayout
        android:id="@+id/cardFormCategoria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="12dp"
        android:background="@drawable/bg_card_elevated"
        android:elevation="3dp"
        android:padding="16dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/etNombreCategoria"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Nombre de la categoría"
            android:paddingLeft="14dp" android:paddingRight="14dp"
            android:paddingTop="0dp" android:paddingBottom="0dp"
            android:background="@drawable/bg_input_field"
            android:textSize="14sp"
            android:textColor="@color/celuaccel_text"
            android:textColorHint="@color/celuaccel_text_light"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGuardarCategoria"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Guardar"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnCancelarCategoria"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/celuaccel_primary"
                android:background="@drawable/bg_btn_outline"/>
        </LinearLayout>
    </LinearLayout>

    <!-- NUEVO: Barra de búsqueda -->
    <EditText
        android:id="@+id/etBusquedaCategoria"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Buscar por ID o nombre..."
        android:inputType="text"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:layout_marginLeft="12dp" android:layout_marginRight="12dp"
        android:layout_marginTop="8dp" android:layout_marginBottom="4dp"
        android:background="@drawable/bg_input_field"
        android:textSize="14sp"
        android:textColor="@color/celuaccel_text"
        android:textColorHint="@color/celuaccel_text_light"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="8dp"/>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCategorias"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/celuaccel_surface"
        android:elevation="2dp"/>

</LinearLayout>
