<?xml version="1.0" encoding="utf-8"?>
<!--
  item_chat.xml — CeluAccel
  Ítem de lista de chats (conversaciones)
  Avatar circular, nombre, último mensaje, hora
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/celuaccel_surface"
    android:paddingLeft="16dp" android:paddingRight="16dp"
    android:paddingTop="14dp" android:paddingBottom="14dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar -->
    <TextView
        android:id="@+id/tvAvatarChat"
        android:layout_width="46dp"
        android:layout_height="46dp"
        android:background="@drawable/bg_avatar_circle"
        android:gravity="center"
        android:text="C"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginEnd="14dp"/>

    <!-- Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvNombreChat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cliente Ejemplo"
            android:textColor="@color/celuaccel_text"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="3dp"/>

        <TextView
            android:id="@+id/tvUltimoMensaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hola, ¿cuándo estará listo mi teléfono?"
            android:textColor="@color/celuaccel_text_muted"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Hora -->
    <TextView
        android:id="@+id/tvHoraChat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="10:30"
        android:textColor="@color/celuaccel_text_light"
        android:textSize="11sp"
        android:layout_marginStart="10dp"/>

    <!-- Separador inferior -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/celuaccel_border"
        android:layout_marginTop="14dp"/>

</LinearLayout>
