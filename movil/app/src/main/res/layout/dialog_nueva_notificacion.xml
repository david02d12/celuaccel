<?xml version="1.0" encoding="utf-8"?>
<!--
  dialog_nueva_notificacion.xml — CeluAccel
  Diálogo para crear notificación — técnico/admin
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_elevated"
    android:padding="0dp">

    <!-- Header del diálogo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nueva Notificación"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <ImageButton
            android:id="@+id/btnCerrarDialog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close_white"
            android:background="@drawable/bg_avatar_white_alpha"
            android:contentDescription="Cerrar"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- Formulario -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="TÍTULO" android:textColor="@color/celuaccel_text_muted"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.06"
            android:layout_marginBottom="6dp"/>

        <EditText android:id="@+id/etTituloNotif"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="Título de la notificación" android:inputType="text"
            android:paddingLeft="14dp" android:paddingRight="14dp" android:paddingTop="0dp" android:paddingBottom="0dp"
            android:background="@drawable/bg_input_field" android:textSize="14sp"
            android:textColor="@color/celuaccel_text" android:textColorHint="@color/celuaccel_text_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="MENSAJE" android:textColor="@color/celuaccel_text_muted"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.06"
            android:layout_marginBottom="6dp"/>

        <EditText android:id="@+id/etMensajeNotif"
            android:layout_width="match_parent" android:layout_height="80dp"
            android:hint="Escribe el mensaje..." android:inputType="textMultiLine"
            android:gravity="top" android:paddingLeft="14dp" android:paddingRight="14dp" android:paddingTop="12dp"
            android:background="@drawable/bg_input_field" android:textSize="14sp"
            android:textColor="@color/celuaccel_text" android:textColorHint="@color/celuaccel_text_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="USUARIO DESTINATARIO (ID)" android:textColor="@color/celuaccel_text_muted"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.06"
            android:layout_marginBottom="6dp"/>

        <EditText android:id="@+id/etDestinatarioNotif"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:hint="Número de documento del usuario" android:inputType="text"
            android:paddingLeft="14dp" android:paddingRight="14dp" android:paddingTop="0dp" android:paddingBottom="0dp"
            android:background="@drawable/bg_input_field" android:textSize="14sp"
            android:textColor="@color/celuaccel_text" android:textColorHint="@color/celuaccel_text_light"
            android:layout_marginBottom="20dp"/>

        <!-- Botones -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnEnviarNotif"
                android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                android:text="Enviar" android:textAllCaps="false" android:textSize="14sp"
                android:textStyle="bold" android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary" android:layout_marginEnd="8dp"/>

            <Button android:id="@+id/btnCancelarNotif"
                android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                android:text="Cancelar" android:textAllCaps="false" android:textSize="14sp"
                android:textColor="@color/celuaccel_primary" android:background="@drawable/bg_btn_outline"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
