<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_login.xml — CeluAccel
  Diseño idéntico al componente Login.jsx del frontend web:
  • Fondo #F4F6F8
  • Card centrada con franja superior roja gradiente
  • Inputs redondeados 10dp con borde sutil
  • Botón primario rojo con sombra
  • Links secundarios alineados
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celuaccel_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingLeft="20dp" android:paddingRight="20dp"
        android:paddingTop="32dp" android:paddingBottom="32dp">

        <!-- ── Mini navbar / Marca ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="20dp" android:paddingRight="20dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CELUACCEL"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

            <Button
                android:id="@+id/btnCatalogoPublico"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Ver Catálogo"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:paddingLeft="14dp" android:paddingRight="14dp"
                android:background="@drawable/bg_btn_outline_white"/>
        </LinearLayout>

        <!-- ── Card principal ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_login"
            android:elevation="8dp">

            <!-- Franja roja superior (igual que en la web) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_header"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp">

                <!-- Ícono de usuario en círculo translúcido -->
                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_avatar_white_alpha"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="&#128100;"
                        android:gravity="center"
                        android:textSize="24sp"/>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenido de vuelta"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ingresa tus credenciales para continuar"
                    android:textColor="#B3FFFFFF"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- ── Formulario ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Label + Campo documento -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NÚMERO DE DOCUMENTO"
                    android:textColor="@color/celuaccel_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="7dp"/>

                <EditText
                    android:id="@+id/id_Usuario"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Ej: 1001234567"
                    android:inputType="number"
                    android:paddingLeft="16dp" android:paddingRight="16dp"
                    android:paddingTop="0dp" android:paddingBottom="0dp"
                    android:background="@drawable/bg_input_field"
                    android:textSize="14sp"
                    android:textColor="@color/celuaccel_text"
                    android:textColorHint="@color/celuaccel_text_light"
                    android:layout_marginBottom="18dp"/>

                <!-- Label + Campo contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTRASEÑA"
                    android:textColor="@color/celuaccel_text_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="7dp"/>

                <EditText
                    android:id="@+id/clave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Ingresa tu contraseña"
                    android:inputType="textPassword"
                    android:paddingLeft="16dp" android:paddingRight="16dp"
                    android:paddingTop="0dp" android:paddingBottom="0dp"
                    android:background="@drawable/bg_input_field"
                    android:textSize="14sp"
                    android:textColor="@color/celuaccel_text"
                    android:textColorHint="@color/celuaccel_text_light"
                    android:layout_marginBottom="24dp"/>

                <!-- Botón principal -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Ingresar al Sistema"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn_primary"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Mensaje de error -->
                <TextView
                    android:id="@+id/tvMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:textColor="@color/celuaccel_primary"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"/>

                <!-- Separador -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/celuaccel_border"
                    android:layout_marginTop="8dp" android:layout_marginBottom="8dp"/>

                <!-- Crear cuenta -->
                <Button
                    android:id="@+id/tvCrearCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Crear cuenta nueva"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/celuaccel_text"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginBottom="8dp"/>

                <!-- Olvidé contraseña -->
                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Olvidé mi contraseña"
                    android:textColor="@color/celuaccel_text_muted"
                    android:textSize="13sp"
                    android:textAlignment="center"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>