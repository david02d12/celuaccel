<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_card_elevated"
        android:elevation="3dp"
        android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
        android:layout_marginBottom="12dp"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true">

    <TextView
            android:id="@+id/tvAvatarCliente"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_avatar_white_alpha"
            android:backgroundTint="@color/celuaccel_primary"
            android:gravity="center"
            android:text="👤"
            android:textSize="18sp"
            android:textColor="#FFFFFF"/>

    <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

        <TextView
                android:id="@+id/tvNombreCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Juan Pérez"
                android:textColor="@color/celuaccel_text"
                android:textSize="15sp"
                android:textStyle="bold"/>

        <TextView
                android:id="@+id/tvDocumentoCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CC — 100234567"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

        <TextView
                android:id="@+id/tvCorreoCliente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="juan.perez@email.com"
                android:textColor="@color/celuaccel_text_light"
                android:textSize="12sp"
                android:layout_marginTop="1dp"/>
    </LinearLayout>

    <TextView
            android:id="@+id/tvBadgeRolCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cliente"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingLeft="10dp" android:paddingRight="10dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            android:background="@drawable/bg_badge_recibido"
            android:textColor="@color/etapa_recibido_text"/>

</LinearLayout>