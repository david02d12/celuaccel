<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celuaccel_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="16dp" android:paddingBottom="16dp"
            android:elevation="6dp">

            <Button
                android:id="@+id/btnRegresar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/bg_avatar_white_alpha"
                android:padding="0dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detalle del Producto"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_img_placeholder">

            <ImageView
                android:id="@+id/imgDetalleProducto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/placeholderDetalle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📦" android:textSize="56sp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SIN IMAGEN" android:textColor="#BBBBBB"
                    android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.08"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </FrameLayout>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="3dp"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvCategoriaDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accesorios"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvNombreDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cargador USB-C 65W"
                android:textColor="@color/celuaccel_text"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvPrecioDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$35.000"
                android:textColor="@color/celuaccel_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/celuaccel_border"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPCIÓN"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDescripcionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descripción del producto disponible próximamente."
                android:textColor="@color/celuaccel_text"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"/>

            <Button
                android:id="@+id/btnHacerPregunta"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="💬 Hacer una Pregunta"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
