<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_solicitar_servicio.xml — CeluAccel
  Pantalla de solicitud de servicio para CLIENTES (rol 2)
  Igual que MiServicio.jsx del frontend web
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/celuaccel_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingTop="16dp" android:paddingBottom="16dp"
            android:elevation="6dp">

            <Button
                android:id="@+id/btnRegresar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:background="@drawable/bg_avatar_white_alpha"
                android:padding="0dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Servicio"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estado de tu reparación"
                    android:textColor="#CCffffff"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Card: Mi servicio activo -->
        <LinearLayout
            android:id="@+id/cardMiServicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="3dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mi Servicio Activo"
                android:textColor="@color/celuaccel_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvDispositivoMio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sin servicio activo"
                android:textColor="@color/celuaccel_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvDescMiServicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No tienes ningún servicio en proceso actualmente."
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvBadgeMiEtapa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingLeft="10dp" android:paddingRight="10dp"
                android:paddingTop="4dp" android:paddingBottom="4dp"
                android:background="@drawable/bg_badge_recibido"
                android:textColor="@color/etapa_recibido_text"
                android:layout_marginBottom="14dp"/>

            <ProgressBar
                android:id="@+id/progressMiServicio"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/celuaccel_primary"
                android:progressBackgroundTint="@color/celuaccel_border"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPorcentajeMi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0% completado"
                android:textColor="@color/celuaccel_text_muted"
                android:textSize="12sp"
                android:textAlignment="center"/>
        </LinearLayout>

        <!-- Card: Solicitar nuevo servicio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="16dp" android:layout_marginRight="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_elevated"
            android:elevation="3dp"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Solicitar Nuevo Servicio"
                android:textColor="@color/celuaccel_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DISPOSITIVO" android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etDispositivoSolicitud"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:hint="Ej: iPhone 13" android:inputType="text"
                android:paddingLeft="14dp" android:paddingRight="14dp" android:paddingTop="0dp" android:paddingBottom="0dp"
                android:background="@drawable/bg_input_field" android:textSize="14sp"
                android:textColor="@color/celuaccel_text" android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DESCRIPCIÓN DEL PROBLEMA" android:textColor="@color/celuaccel_text_muted"
                android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/etDescripcionSolicitud"
                android:layout_width="match_parent" android:layout_height="90dp"
                android:hint="Describe el problema con tu dispositivo..."
                android:inputType="textMultiLine" android:gravity="top"
                android:paddingLeft="14dp" android:paddingRight="14dp" android:paddingTop="12dp"
                android:background="@drawable/bg_input_field" android:textSize="14sp"
                android:textColor="@color/celuaccel_text" android:textColorHint="@color/celuaccel_text_light"
                android:layout_marginBottom="20dp"/>

            <Button android:id="@+id/btnEnviarSolicitud"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="Enviar Solicitud" android:textAllCaps="false"
                android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"
                android:background="@drawable/bg_btn_primary" android:elevation="3dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
