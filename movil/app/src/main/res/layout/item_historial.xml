<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_elevated"
    android:elevation="3dp"
    android:layout_marginLeft="4dp" android:layout_marginRight="4dp"
    android:layout_marginBottom="10dp"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvIdHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Servicio #001"
            android:textColor="@color/celuaccel_text"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvEtapaHistorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Listo"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingLeft="10dp" android:paddingRight="10dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            android:background="@drawable/bg_badge_listo"
            android:textColor="@color/etapa_listo_text"/>
    </LinearLayout>

    
    <TextView
        android:id="@+id/tvDispositivoHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Samsung Galaxy S22"
        android:textColor="@color/celuaccel_text_muted"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"/>

    
    <TextView
        android:id="@+id/tvDescHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cambio de batería"
        android:textColor="@color/celuaccel_text_muted"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="8dp"/>

    
    <ProgressBar
        android:id="@+id/progressHistorial"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="100"
        android:progressTint="@color/celuaccel_success"
        android:progressBackgroundTint="@color/celuaccel_border"
        android:layout_marginBottom="8dp"/>

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvFechaHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📅 15/05/2025"
            android:textColor="@color/celuaccel_text_muted"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvPrecioHistorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$80.000"
            android:textColor="@color/celuaccel_success"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
