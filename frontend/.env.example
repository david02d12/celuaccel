# ─── CONFIGURACIÓN DE ENTORNO — FRONTEND CeluAccel ──────────────────
# Copia este archivo como ".env.local" y ajusta las URLs.
# Vite prioriza: .env.local > .env > valores por defecto
#
# Comando:
#   Windows: copy .env.example .env.local
#   Linux/Mac: cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────

# URL del backend (API)
# Desarrollo local (misma máquina):
VITE_API_URL=http://localhost:3000/api

# Desarrollo en red LAN (backend en otra máquina / acceso desde Android):
# VITE_API_URL=http://192.168.80.15:3000/api

# Producción:
# VITE_API_URL=https://api.tudominio.com/api
