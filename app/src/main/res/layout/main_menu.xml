<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#D32F2F"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textViewTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="CeluAccel"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="#FFFFFF"/>

            <!-- Badge notificaciones no leídas -->
            <TextView
                android:id="@+id/tvBadgeMenu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FF6F00"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Fila 1: Usuarios | Servicios -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- USUARIOS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="4dp"
                android:layout_margin="8dp">
                <ImageButton
                    android:id="@+id/btnCliente"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    app:srcCompat="@mipmap/clientes"
                    android:background="@android:color/transparent"
                    android:contentDescription="Usuarios"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Usuarios"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- SERVICIOS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="4dp"
                android:layout_margin="8dp">
                <ImageButton
                    android:id="@+id/btnServicio"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    app:srcCompat="@mipmap/cargador"
                    android:background="@android:color/transparent"
                    android:contentDescription="Servicios"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Servicios"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fila 2: Productos | Chats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- PRODUCTOS / CATÁLOGO -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="4dp"
                android:layout_margin="8dp">
                <ImageButton
                    android:id="@+id/btnCompras"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    app:srcCompat="@mipmap/compras"
                    android:background="@android:color/transparent"
                    android:contentDescription="Productos"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Productos"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- CHATS -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="4dp"
                android:layout_margin="8dp">
                <ImageButton
                    android:id="@+id/btnChat"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    app:srcCompat="@mipmap/ic_launcher"
                    android:background="@android:color/transparent"
                    android:contentDescription="Chats"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chats"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Fila 3: Notificaciones | Perfil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- NOTIFICACIONES -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="4dp"
                android:layout_margin="8dp">
                <ImageButton
                    android:id="@+id/btnGear"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    app:srcCompat="@mipmap/campana"
                    android:background="@android:color/transparent"
                    android:contentDescription="Notificaciones"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notificaciones"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- PERFIL -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="10dp"
                android:elevation="4dp"
                android:layout_margin="8dp">
                <ImageButton
                    android:id="@+id/btnPerfil"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    app:srcCompat="@mipmap/clientes"
                    android:background="@android:color/transparent"
                    android:contentDescription="Mi Perfil"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi Perfil"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Cerrar sesión -->
        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar Sesión"
            android:backgroundTint="#D32F2F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>