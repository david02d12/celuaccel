<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D32F2F"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notificaciones"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnMarcarTodasLeidas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Marcar todas leídas"
            android:textSize="11sp"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- Badge de no leídas -->
    <TextView
        android:id="@+id/tvBadgeNoLeidas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFEBEE"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="Cargando notificaciones..."
        android:textColor="#C62828"
        android:textSize="13sp"
        android:visibility="gone"/>

    <ProgressBar
        android:id="@+id/progressBarNotif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvSinNotificaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:text="No tienes notificaciones"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNotificaciones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <Button
        android:id="@+id/btnRegresarNotif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Regresar"
        android:backgroundTint="#757575"
        android:textColor="#FFFFFF"/>

</LinearLayout>
