<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Solicitar Mantenimiento"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:background="#FF0000"
        android:padding="15dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Por favor, describe el problema con tu dispositivo:"
        android:textSize="16sp"
        android:layout_marginBottom="10dp" />

    <EditText
        android:id="@+id/txtDescripcionProblema"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej. La pantalla está rota, no enciende..."
        android:inputType="textMultiLine"
        android:lines="4"
        android:gravity="top|start"
        android:background="@android:color/white"
        android:padding="10dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/txtMarcaModelo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Marca y Modelo (Ej. Samsung Galaxy S21)"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="10dp"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/txtEspecificaciones"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Especificaciones (Ej. 128GB, Color Negro)"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="10dp"
        android:layout_marginBottom="25dp"/>

    <Button
        android:id="@+id/btnEnviarSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar Solicitud"
        android:backgroundTint="#FF0000"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnMisSolicitudes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ver mis solicitudes"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="15dp"/>

    <Button
        android:id="@+id/btnRegresarSolicitud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Regresar al Menú"
        android:backgroundTint="#808080"
        android:textColor="#FFFFFF" />

</LinearLayout>
