<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="#FFFFFF"
    android:elevation="2dp">

    <!-- Indicador de leída/no leída -->
    <View
        android:id="@+id/viewIndicadorLeida"
        android:layout_width="6dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="12dp"
        android:background="#D32F2F"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloNotificacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#212121"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvMensajeNotificacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Mensaje de la notificación"
            android:textColor="#616161"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvFechaNotificacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Fecha"
            android:textColor="#9E9E9E"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Botón marcar leída -->
    <ImageButton
        android:id="@+id/btnMarcarLeida"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Marcar como leída"
        android:src="@android:drawable/checkbox_on_background"/>

</LinearLayout>
