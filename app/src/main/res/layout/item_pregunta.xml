<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="#FFFFFF"
    android:elevation="2dp"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvPreguntaTexto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pregunta del cliente"
            android:textColor="#212121"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvFechaPregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/2025"
            android:textColor="#9E9E9E"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Respuesta (si existe) -->
    <LinearLayout
        android:id="@+id/layoutRespuesta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:background="#FFEBEE"
        android:padding="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Respuesta:"
            android:textColor="#D32F2F"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvRespuestaPregunta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Respuesta aquí"
            android:textColor="#424242"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Sin respuesta -->
    <TextView
        android:id="@+id/tvSinRespuesta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Pendiente de respuesta"
        android:textColor="#FF8F00"
        android:textSize="12sp"
        android:visibility="visible"/>

</LinearLayout>
